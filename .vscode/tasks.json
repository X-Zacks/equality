{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "desktop: tauri dev",
			"type": "shell",
			"command": "pnpm --filter @equality/desktop tauri:dev",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "desktop: tauri dev (with cargo)",
			"type": "shell",
			"command": "$env:PATH += ';' + \"$env:USERPROFILE\\.cargo\\bin\"; pnpm --filter @equality/desktop tauri:dev",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "tauri-dev",
			"type": "shell",
			"command": "$cargoPath = Join-Path $env:USERPROFILE '.cargo' 'bin'; $env:PATH = $env:PATH + ';' + $cargoPath; pnpm --filter @equality/desktop tauri:dev",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "tauri-dev-cmd",
			"type": "shell",
			"command": "cmd /c \"set PATH=%PATH%;%USERPROFILE%\\.cargo\\bin && pnpm --filter @equality/desktop tauri:dev\"",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "tauri-dev-final",
			"type": "shell",
			"command": ".\\run-tauri-dev.cmd",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "core-dev",
			"type": "shell",
			"command": "$env:CUSTOM_API_KEY='sk-PDilWPt_Z_IRzwQbSfhE6g'; $env:CUSTOM_BASE_URL='https://aiverse-row.ludp.lenovo.com/ics-apps/projects/115/dev-test/aiverse/endpoint/v1'; $env:CUSTOM_MODEL='gpt-4o'; pnpm --filter @equality/core dev",
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "kill-node",
			"type": "shell",
			"command": "Get-Process -Name node -ErrorAction SilentlyContinue | Stop-Process -Force",
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "typecheck",
			"type": "shell",
			"command": "pnpm typecheck",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "typecheck-desktop",
			"type": "shell",
			"command": "pnpm --filter @equality/desktop tsc --noEmit",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "typecheck-desktop-2",
			"type": "shell",
			"command": "cd packages/desktop ; npx tsc --noEmit",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "typecheck-desktop-3",
			"type": "shell",
			"command": "cd packages/desktop ; npx tsc --noEmit",
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			]
		}
	]
}